{
  "rewrites": [
    {
      "source": "/api/check",
      "destination": "/api/check.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/verify_ipsita.txt",
      "destination": "/frontend/verify_ipsita.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}